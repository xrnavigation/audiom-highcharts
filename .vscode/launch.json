{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Sample: Vite dev server",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev:sample"],
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "name": "Sample: Open in Chrome",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:5173",
      "webRoot": "${workspaceFolder}/sample"
    },
    {
      "name": "Plugin: Build",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "build:plugin"],
      "console": "integratedTerminal"
    },
    {
      "name": "Plugin: Test",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "test:plugin"],
      "console": "integratedTerminal"
    }
  ],
  "compounds": [
    {
      "name": "Sample: Dev + Browser",
      "configurations": ["Sample: Vite dev server", "Sample: Open in Chrome"]
    }
  ]
}
