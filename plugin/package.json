{
  "name": "audiom-highcharts",
  "version": "0.1.0-dev",
  "type": "module",
  "description": "Highcharts plugin that adds Audiom audio accessibility to map charts.",
  "main": "dist/audiom-highcharts.umd.cjs",
  "module": "dist/audiom-highcharts.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/audiom-highcharts.mjs",
      "require": "./dist/audiom-highcharts.umd.cjs"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "rollup -c",
    "dev": "rollup -c -w",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "highcharts": ">=10.0.0"
  },
  "dependencies": {
    "@xrnavigation/audiom-embedder": "^1.0.0",
    "topojson-client": "^3.1.0"
  },
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@rollup/plugin-typescript": "^11.1.6",
    "@types/topojson-client": "^3.1.5",
    "highcharts": "^11.4.0",
    "rollup": "^4.18.0",
    "rollup-plugin-dts": "^6.1.1",
    "tslib": "^2.6.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
